# Steam leaderboard backend config
# not intended for open source use, this is for the Steam integration of Rind
# if using this engine for another project, the same patterns can be used for your own backend
# backend submit endpoint, not a secret (ships with the game)
RIND_LEADERBOARD_URL=https://your-server.example/submit

# optional soft gate sent as the X-App-Token header, not for security
# real auth is the Steam Web API ticket the client sends
#RIND_LEADERBOARD_TOKEN=
